# --- Joe assistant (server-side ONLY; never expose to the client) ---

# Anthropic API key for Joe. Required for the /api/joe route to work.
# Add the real value to .env.local (gitignored) and to Vercel project env vars.
# NEVER prefix with NEXT_PUBLIC_ and never commit a real key.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: hosted rate-limit store for Joe + contact form (Upstash Redis REST).
# If unset, the routes fall back to a per-instance in-memory limiter.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Contact / "Book a call" form (server-side ONLY) ---

# Resend API key — required for the /api/contact route to actually send email.
# Without it, submissions are accepted and logged but no email is sent.
RESEND_API_KEY=your_resend_api_key_here

# Inbox that receives booking requests (defaults to hello@jwebly.co.uk).
# CONTACT_TO=hello@jwebly.co.uk

# Verified Resend sender. For local dev you can use Resend's sandbox sender
# "Jwebly <onboarding@resend.dev>"; in production use a verified domain address.
# CONTACT_FROM=Jwebly <hello@jwebly.co.uk>
